{
  "name": "tinytrail",
  "private": true,
  "version": "1.0.0",
  "description": "URL shortener with built-in quirkiness ;)",
  "license": "ISC",
  "author": "ksaswin",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "format": "prettier --write '**/*.{ts,tsx,js,jsx,json,css}'",
    "format:check": "prettier --check '**/*.{ts,tsx,js,jsx,json,css}'",
    "supabase:gentypes": "supabase gen types typescript --local --schema tinytrail > packages/database/src/entities.ts",
    "supabase:start": "supabase start"
  },
  "devDependencies": {
    "prettier": "^3.8.1"
  }
}
